# ============================================================
# Production Environment Variables Template
# ============================================================
# Copy this file and fill in real values:
#   cp deploy/.env.production.example backend/.env.production
# ============================================================

# ----- Application -----
APP_ENV=production
APP_PORT=8080
ALLOWED_ORIGINS=https://halalcore.id,https://telemarketing.halalcore.id
APP_FRONTEND_URL=https://halalcore.id
TELEMARKETING_URL=https://telemarketing.halalcore.id

# ----- Database (PostgreSQL on same VPS) -----
DB_HOST=localhost
DB_PORT=5432
DB_USER=ananahnu
DB_PASSWORD=<CHANGE_ME>
DB_NAME=ananahnu

# ----- JWT -----
JWT_SECRET=<GENERATE_64_CHAR_RANDOM_STRING>
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=7

# ----- SMTP -----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your_email@gmail.com>
SMTP_PASS=<your_app_password>

# ----- Midtrans -----
MIDTRANS_SERVER_KEY=<your_server_key>
MIDTRANS_CLIENT_KEY=<your_client_key>
MIDTRANS_IS_PRODUCTION=false

# ----- Fonnte WhatsApp -----
FONNTE_TOKEN=<your_fonnte_token>

# ----- Telegram -----
TELEGRAM_BOT_TOKEN=<your_telegram_bot_token>
